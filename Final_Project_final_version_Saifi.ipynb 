    "# Identify numeric and categorical columns based on the training data\n",
    "numeric_features = X_train.select_dtypes(include=[np.number]).columns.tolist()\n",
    "categorical_features = X_train.select_dtypes(exclude=[np.number]).columns.tolist()\n",
    "\n",
    "\n",
    "# IQR-based outlier summary (training set only)\n",
    "# This is for documentation: we count how many values fall outside the 1.5*IQR range.\n",
    "rows = []\n",
    "for col in numeric_features:\n",
    "    q1 = X_train[col].quantile(0.25)\n",
    "    q3 = X_train[col].quantile(0.75)\n",
    "    iqr = q3 - q1\n",
    "\n",
    "    if iqr == 0:\n",
    "        # No spread = no detectable IQR outliers\n",
    "        lower, upper = q1, q3\n",
    "        out_count = 0\n",
    "    else:\n",
    "        lower = q1 - 1.5 * iqr\n",
    "        upper = q3 + 1.5 * iqr\n",
    "        out_count = int(((X_train[col] < lower) | (X_train[col] > upper)).sum())\n",
    "\n",
    "    rows.append((col, out_count, float(lower), float(upper)))\n",
    "\n",
    "outlier_tbl = (\n",
    "    pd.DataFrame(rows, columns=[\"feature\", \"IQR_outliers_count\", \"IQR_lower\", \"IQR_upper\"])\n",
    "    .sort_values(\"IQR_outliers_count\", ascending=False)\n",
    ")\n",
    "\n",
    "display(outlier_tbl.head(10))\n",
    "\n",
    "\n",
    "# Quantile-based clipping (learned from training data) \n",
    "# We clip instead of deleting rows to keep rare but valid observations.\n",
    "clip_bounds = []\n",
    "X_train_before_clip = X_train.copy()  # keep a copy for visual comparison\n",
    "\n",
    "for col in numeric_features:\n",
    "    lower = X_train[col].quantile(0.01)\n",
    "    upper = X_train[col].quantile(0.99)\n",
    "\n",
    "    clip_bounds.append((col, float(lower), float(upper)))\n",
    "\n",
    "    # Apply same bounds to both splits (no refitting on test)\n",
    "    X_train[col] = X_train[col].clip(lower, upper)\n",
    "    X_test[col]  = X_test[col].clip(lower, upper)\n",
    "\n",
    "clip_bounds_tbl = pd.DataFrame(\n",
    "    clip_bounds,\n",
    "    columns=[\"feature\", \"clip_lower_q01\", \"clip_upper_q99\"]\n",
    ")\n",
    "\n",
    "display(clip_bounds_tbl.head(10))\n",
    "\n",
    "\n",
    "# Visual check: before vs after clipping\n",
    "# Show boxplots for the features with the most IQR outliers.\n",
    "top_cols = outlier_tbl[\"feature\"].head(4).tolist()\n",
    "\n",
    "plt.figure(figsize=(12, 4))\n",
    "for i, col in enumerate(top_cols, 1):\n",
    "    plt.subplot(1, 4, i)\n",
    "    plt.boxplot(\n",
    "        [X_train_before_clip[col].dropna(), X_train[col].dropna()],\n",
    "        tick_labels=[\"before\", \"after\"]\n",
    "    )\n",
    "    plt.title(col)\n",
    "\n",
    "plt.suptitle(\"Figure 6.1: Outlier clipping effect (training set)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
